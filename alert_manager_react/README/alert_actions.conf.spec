[create_incident]

param.severity = <string>
    * Severity level for the created incident.
    * Accepted values: critical, high, medium, low, info
    * Default: medium

param.title = <string>
    * Title for the incident.
    * Optional. If omitted, the alert name is used as the title.

param.description = <string>
    * Description / notes for the incident.
    * Optional. If omitted, a default message noting the alert name is used.
